NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/NaturalStore
JWT_ACCESS_SECRET=replace_access_secret
JWT_REFRESH_SECRET=replace_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# ── Gửi mail: chọn 1 cách (ưu tiên Brevo → Mailjet → Resend → SMTP) ─────
# Cách 1 — Brevo (khuyến nghị trên Render, không cần domain):
#   brevo.com → My Account → SMTP & API → API Keys → tạo key
#   Senders → thêm Gmail của bạn → xác minh qua email
# BREVO_API_KEY=xkeysib-xxxx
# BREVO_SENDER_EMAIL=your_email@gmail.com
# BREVO_SENDER_NAME=Natural Store
# Cách 2 — Mailjet (Free, không bắt buộc domain — xác minh Gmail làm sender):
# mailjet.com → REST API → API Key + Secret Key | Senders → xác minh email
# MAILJET_API_KEY=xxxxxxxx
# MAILJET_SECRET_KEY=xxxxxxxx
# MAILJET_SENDER_EMAIL=your_verified@gmail.com
# MAILJET_SENDER_NAME=Natural Store
# Cách 3 — Resend:
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=Natural Store <onboarding@resend.dev>
# Cách 4 — SMTP Gmail (thường bị timeout trên Render):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloud_key
CLOUDINARY_API_SECRET=your_cloud_secret
# Chatbot: mock = rule-based | openai = gọi OpenAI (cần AI_API_KEY)
AI_PROVIDER=mock
AI_API_KEY=
# Tên model Chat Completions (vd: gpt-4o-mini). Bỏ trống hoặc để mặc định dưới đây.
AI_MODEL=gpt-4o-mini
CLIENT_URL=http://localhost:5173
ALLOW_GUEST_CHECKOUT=true
